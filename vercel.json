{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "other",
  "serverlessFunctionRegion": "auto",
  "env": {
    "GEMINI_API_KEY": "@GEMINI_API_KEY",
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
